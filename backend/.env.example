# Server
PORT=5000
NODE_ENV=development

# Client origin allowed to connect (CORS + Socket.io)
CLIENT_ORIGIN=http://localhost:5173

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/realtime_collab

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# AES-256 key used to encrypt uploaded files at rest.
# Must be exactly 32 bytes. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FILE_ENCRYPTION_KEY=replace_this_with_a_64_char_hex_string_32_bytes
